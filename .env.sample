# Only needed for dev tooling
DEV_PG_ADDRESS="localhost:5432"
DEV_PG_PASSWORD="" # TODO: Pick a password for dev postgres instance

# ===============================================================================
# zero-cache config
# ===============================================================================

# This needs to be a "direct" (unpooled) Postgres connection to support logical
# replication.
ZERO_UPSTREAM_DB="postgres://postgres:$DEV_PG_PASSWORD@$DEV_PG_ADDRESS/pi-dash"

ZERO_ADMIN_PASSWORD=""  # TODO: Pick a password to authenticate admin tools
ZERO_MUTATE_FORWARD_COOKIES="true"
ZERO_MUTATE_URL="http://localhost:3001/api/zero/mutate"
ZERO_QUERY_FORWARD_COOKIES="true"
ZERO_QUERY_URL="http://localhost:3001/api/zero/query"
ZERO_LOG_LEVEL="debug"
ZERO_REPLICA_FILE="/tmp/zero.db"

# ===============================================================================
# app config
# ===============================================================================

# In production, this should be a pooled connection to conserve connections.
DATABASE_URL="$ZERO_UPSTREAM_DB"

BETTER_AUTH_SECRET="" # TODO: Pick a password for better-auth
BETTER_AUTH_URL=http://localhost:3001
VITE_PUBLIC_ZERO_CACHE_URL="http://localhost:4848"
GRAVATAR_ACCESS_TOKEN="" # TODO: Set Gravatar API bearer token
GRAVATAR_DICEBEAR_SEED="" # TODO: Set namespace seed for DiceBear fallback
GRAVATAR_API_BASE_URL="https://api.gravatar.com/v3"
GRAVATAR_TIMEOUT_MS=5000

# Set to `.yourdomain.com` to enable cookie auth in prod
# See https://zero.rocicorp.dev/docs/auth#cookie-based-auth
COOKIE_DOMAIN=""
CORS_ORIGIN=http://localhost:3001

# Admin bootstrap user for `bun run auth:seed-admin`
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# SMTP email config (use Mailpit for local dev)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# R2 info for file uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_KEY_ID=""
R2_BUCKET_NAME="pi-dash"
ASSET_FOLDER="attachments"
VITE_ASSET_CDN=""

# Courier notifications
COURIER_API_KEY=""

# WhatsApp notifications (optional — leave blank to disable)
WHATSAPP_API_URL=""        # e.g. http://localhost:3100
WHATSAPP_AUTH_USER="admin"
WHATSAPP_AUTH_PASS="admin"

# Immich photo server (optional — leave blank to disable)
IMMICH_SERVER_URL=""       # e.g. http://localhost:2283
IMMICH_API_KEY=""

# App URL shown in notification footers (optional)
APP_URL=""                 # e.g. https://dash.proudindian.ngo
