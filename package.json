{
  "name": "pi-dash",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.4.3",
      "vite": "^8.1.3",
      "typescript": "^7.0.2",
      "dotenv": "^17.4.2",
      "dotenv-expand": "^13.0.0",
      "drizzle-orm": "^0.45.2",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "date-fns": "^4.4.0",
      "lodash": "^4.18.1",
      "evlog": "^2.20.0",
      "@types/lodash": "^4.17.24",
      "@rocicorp/zero": "^1.7.0",
      "@types/bun": "^1.3.14",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@hugeicons/core-free-icons": "^4.2.2",
      "@hugeicons/react": "^1.1.9",
      "@dnd-kit/core": "^6.3.1",
      "@dnd-kit/sortable": "^10.0.0",
      "@dnd-kit/utilities": "^3.2.2",
      "@vitejs/plugin-react": "^6.0.3",
      "babel-plugin-react-compiler": "^1.0.0",
      "sonner": "^2.0.7",
      "better-auth": "^1.6.23",
      "uuidv7": "^1.2.1",
      "tailwindcss": "^4.3.2",
      "@tailwindcss/vite": "^4.3.2",
      "@playwright/test": "^1.61.1",
      "platejs": "^53.2.4",
      "@platejs/basic-nodes": "^53.0.0",
      "@platejs/caption": "^53.0.0",
      "@platejs/link": "^53.3.1",
      "@platejs/list-classic": "^53.0.0",
      "@platejs/media": "^53.1.4",
      "@platejs/floating": "^53.0.0",
      "@platejs/resizable": "^53.0.0",
      "@platejs/code-block": "^53.0.0",
      "@platejs/combobox": "^53.0.0",
      "@platejs/dnd": "^53.1.0",
      "@platejs/emoji": "^53.1.7",
      "@platejs/indent": "^53.0.0",
      "@platejs/mention": "^53.0.0",
      "@platejs/selection": "^53.1.6",
      "@platejs/slash-command": "^53.0.0",
      "@platejs/table": "^53.0.9",
      "@platejs/toggle": "^53.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:kill": "bash scripts/dev-kill.sh",
    "build": "turbo run build",
    "check:types": "bun run --env-file .env -- turbo run check:types",
    "dev:web": "turbo run --filter=web dev",
    "dev:webhook-proxy": "bun --env-file=.env run scripts/dev-whatsapp-webhook-proxy.ts",
    "db:push": "turbo run --filter=@pi-dash/db db:push",
    "db:studio": "turbo run --filter=@pi-dash/db db:studio",
    "db:generate": "turbo run --filter=@pi-dash/db db:generate",
    "db:migrate": "turbo run --filter=@pi-dash/db db:migrate",
    "db:start": "turbo run --filter=@pi-dash/db db:start",
    "db:watch": "turbo run --filter=@pi-dash/db db:watch",
    "db:stop": "turbo run --filter=@pi-dash/db db:stop",
    "db:down": "turbo run --filter=@pi-dash/db db:down",
    "whatsapp:start": "turbo run --filter=@pi-dash/db whatsapp:start",
    "whatsapp:stop": "turbo run --filter=@pi-dash/db whatsapp:stop",
    "auth:seed-admin": "turbo run --filter=@pi-dash/auth auth:seed-admin",
    "zero:generate": "turbo run --filter=@pi-dash/zero zero:generate",
    "zero:analyze": "turbo run --filter=@pi-dash/zero zero:analyze",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "check:unused": "SKIP_VALIDATION=true knip",
    "check:updates": "bunx taze -I --recursive",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "r2:migrate-media-urls": "bun --env-file=.env --env-file=.env.worktree run scripts/migrate-r2-media-urls.ts",
    "ui:add": "turbo run --filter=@pi-dash/design-system ui:add --",
    "test:unit": "turbo run test:unit",
    "test:seed": "turbo run --filter=@pi-dash/e2e seed",
    "test:e2e": "turbo run --filter=@pi-dash/e2e test",
    "test:e2e:ui": "turbo run --filter=@pi-dash/e2e test:ui",
    "analyze": "turbo run --filter=web analyze",
    "worktree:setup": "bash scripts/worktree-setup.sh",
    "worktree:teardown": "bash scripts/worktree-teardown.sh",
    "seed": "bun --env-file=.env --env-file=.env.worktree run scripts/seed.ts"
  },
  "dependencies": {
    "@pi-dash/auth": "workspace:*",
    "@pi-dash/db": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@pi-dash/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "knip": "^6.25.0",
    "lefthook": "2.1.10",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "ultracite": "7.9.3",
    "uuidv7": "^1.2.1",
    "vite-bundle-analyzer": "^1.3.8",
    "vitest": "^4.1.10"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3",
    "lefthook"
  ]
}
