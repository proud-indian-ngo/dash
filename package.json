{
  "name": "pi-dash",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.3.6",
      "vite": "^8.0.0-beta.18",
      "typescript": "^5.9.3",
      "dotenv": "^17.3.1",
      "dotenv-expand": "^12.0.3",
      "drizzle-orm": "^0.45.1",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "date-fns": "^4.1.0",
      "lodash": "^4.17.23",
      "@types/lodash": "^4.17.24",
      "@rocicorp/zero": "^0.25.13",
      "@types/bun": "^1.3.10",
      "@types/node": "^25.4.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@hugeicons/core-free-icons": "^4.0.0",
      "@hugeicons/react": "^1.1.6",
      "@dnd-kit/core": "^6.3.1",
      "@dnd-kit/sortable": "^10.0.0",
      "@dnd-kit/utilities": "^3.2.2",
      "@vitejs/plugin-react": "^5.1.4",
      "babel-plugin-react-compiler": "^1.0.0",
      "sonner": "^2.0.7",
      "better-auth": "^1.5.4",
      "uuidv7": "^1.1.0",
      "tailwindcss": "^4.2.1",
      "@tailwindcss/vite": "^4.2.1",
      "@playwright/test": "^1.58.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check:types": "turbo check:types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @pi-dash/db db:push",
    "db:studio": "turbo -F @pi-dash/db db:studio",
    "db:generate": "turbo -F @pi-dash/db db:generate",
    "db:migrate": "turbo -F @pi-dash/db db:migrate",
    "db:start": "turbo -F @pi-dash/db db:start",
    "db:watch": "turbo -F @pi-dash/db db:watch",
    "db:stop": "turbo -F @pi-dash/db db:stop",
    "db:down": "turbo -F @pi-dash/db db:down",
    "whatsapp:start": "turbo -F @pi-dash/db whatsapp:start",
    "whatsapp:stop": "turbo -F @pi-dash/db whatsapp:stop",
    "auth:seed-admin": "turbo -F @pi-dash/auth auth:seed-admin",
    "zero:generate": "turbo -F @pi-dash/zero zero:generate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "check:unused": "SKIP_VALIDATION=true knip",
    "check:updates": "bunx taze -I --recursive",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "ui:add": "turbo -F @pi-dash/design-system ui:add --",
    "test:unit": "turbo test:unit",
    "test:seed": "turbo -F @pi-dash/e2e seed",
    "test:e2e": "turbo -F @pi-dash/e2e test",
    "test:e2e:ui": "turbo -F @pi-dash/e2e test:ui"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@pi-dash/config": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "knip": "^5.86.0",
    "lefthook": "2.1.1",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "ultracite": "7.2.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.10",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3",
    "lefthook"
  ]
}
