{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "includes": [
      "**/*",
      "!.agents/**/*",
      "!.claude/**/*",
      "!.worktrees/**/*",
      "!packages/design-system/components",
      "!packages/design-system/lib/utils.ts",
      "!packages/design-system/hooks/use-mobile.ts",
      "!packages/design-system/styles.css",
      "!packages/db/src/migrations/**/*",
      "!packages/zero/src/schema.ts",
      "!apps/web/src/routeTree.gen.ts"
    ]
  },
  "overrides": [
    {
      "includes": [
        "apps/web/src/routes/api/auth/$.ts",
        "apps/web/src/routes/api/immich/thumbnail.$id.ts",
        "apps/web/src/routes/api/immich/original.$id.ts",
        "apps/web/src/routes/_app/settings/roles/$roleId.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/e2e/**/*.ts"],
      "linter": {
        "rules": {
          "performance": {
            "useTopLevelRegex": "off"
          },
          "suspicious": {
            "noSkippedTests": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "noExportedImports": "off"
          }
        }
      }
    }
  ]
}
