{
  "name": "@pi-dash/zero",
  "type": "module",
  "exports": {
    "./context": "./src/context.ts",
    "./schema": "./src/schema.ts",
    "./queries": "./src/queries.ts",
    "./mutators": "./src/mutators.ts",
    "./vendor-patterns": "./src/vendor-patterns.ts",
    "./vendor-payment-constants": "./src/vendor-payment-constants.ts",
    "./rrule-utils": "./src/lib/rrule-utils.ts"
  },
  "scripts": {
    "dev": "bun run --env-file=../../.env --env-file=../../.env.worktree zero-cache-dev",
    "zero:generate": "drizzle-zero generate -f -s ../db/src/schema/index.ts -o src/schema.ts",
    "check:types": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@pi-dash/db": "workspace:*",
    "@pi-dash/env": "workspace:*",
    "@pi-dash/jobs": "workspace:*",
    "@pi-dash/notifications": "workspace:*",
    "@rocicorp/zero": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zero": "^0.18.0",
    "rrule": "^2.8.1",
    "uuidv7": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pi-dash/config": "workspace:*",
    "typescript": "catalog:"
  }
}
