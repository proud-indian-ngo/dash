{
  "name": "@pi-dash/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun --env-file=../../.env run scripts/migrate.ts",
    "db:start": "bun --env-file=../../.env run docker compose up -d",
    "db:watch": "bun --env-file=../../.env run docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "whatsapp:start": "bun --env-file=../../.env run docker compose up -d whatsapp",
    "whatsapp:stop": "docker compose stop whatsapp",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@pi-dash/env": "workspace:*",
    "drizzle-orm": "catalog:",
    "uuidv7": "catalog:"
  },
  "devDependencies": {
    "@pi-dash/config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
