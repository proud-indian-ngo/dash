{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "check:types": {
      "dependsOn": ["transit"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:start": {
      "cache": false,
      "persistent": true
    },
    "db:stop": {
      "cache": false
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:down": {
      "cache": false
    },
    "auth:seed-admin": {
      "cache": false
    },
    "zero:generate": {
      "cache": false
    },
    "zero:analyze": {
      "cache": false,
      "env": [
        "COOKIE",
        "ZERO_ADMIN_PASSWORD",
        "ZERO_ANALYZE_EVENT_ID",
        "ZERO_AUTH_TOKEN",
        "ZERO_CACHE_URL"
      ]
    },
    "ui:add": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "test:unit": {
      "cache": false
    },
    "test:ui": {
      "cache": false
    },
    "whatsapp:start": {
      "cache": false
    },
    "whatsapp:stop": {
      "cache": false
    },
    "analyze": {
      "cache": false
    }
  }
}
