{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "ignoreDependencies": ["@biomejs/biome", "@commitlint/cli"],
  "ignoreIssues": {
    "src/generated/**": ["exports", "types"],
    "**/*.generated.ts": ["exports", "types"],
    "packages/design-system/components/**": ["exports", "types"],
    "packages/zero/src/schema.ts": ["duplicates"]
  },
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {},
    "apps/web": {
      "ignoreFiles": [
        "src/entry-server.ts",
        "server/**",
        "src/lib/logger.ts",
        "src/stubs/**",
        "src/components/vendors/**",
        "src/routes/_app/vendors/**"
      ]
    },
    "packages/db": {
      "ignoreFiles": ["scripts/**"],
      "ignoreDependencies": ["uuidv7"]
    },
    "packages/e2e": {
      "ignoreFiles": ["global-setup.ts"]
    },
    "packages/design-system": {
      "ignoreFiles": ["components/**", "hooks/**", "styles.css"],
      "ignoreDependencies": [
        "@tailwindcss/.*",
        "tailwindcss",
        "tw-animate-css",
        "@fontsource-variable/inter"
      ]
    }
  }
}
