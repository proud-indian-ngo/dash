{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "ignoreDependencies": ["@biomejs/biome", "@commitlint/cli"],
  "ignoreIssues": {
    "src/generated/**": ["exports", "types"],
    "**/*.generated.ts": ["exports", "types"],
    "packages/design-system/components/**": ["exports", "types"],
    "packages/zero/src/schema.ts": ["duplicates"]
  },
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {},
    "apps/web": {
      "ignoreFiles": [
        "src/entry-server.ts",
        "server/**",
        "src/lib/logger.ts",
        "src/stubs/**"
      ]
    },
    "packages/db": {
      "ignoreFiles": ["scripts/**"],
      "ignoreDependencies": ["uuidv7", "@pi-dash/auth"]
    },
    "packages/e2e": {
      "ignoreFiles": ["global-setup.ts"],
      "entry": ["helpers/seed-dev-data.ts"],
      "ignoreDependencies": ["better-auth"]
    },
    "packages/jobs": {
      "ignoreDependencies": ["@pi-dash/observability"]
    },
    "packages/email": {
      "ignoreFiles": [
        "src/templates/notification-approval-with-image.tsx",
        "src/templates/notification-minimal.tsx",
        "src/templates/notification-with-line-items.tsx"
      ]
    },
    "packages/design-system": {
      "ignoreFiles": ["components/**", "hooks/**"],
      "ignoreDependencies": ["@tailwindcss/.*"]
    }
  }
}
