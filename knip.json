{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "ignoreDependencies": [
    "@biomejs/biome",
    "@commitlint/cli",
    "@posthog/cli",
    "uuidv7"
  ],
  "ignoreIssues": {
    "src/generated/**": ["exports", "types"],
    "**/*.generated.ts": ["exports", "types"],
    "packages/design-system/components/**": ["exports", "types"],
    "packages/editor/components/**": ["exports", "types", "unlisted"],
    "packages/zero/src/schema.ts": ["duplicates", "exports", "types"],
    "packages/db/src/schema/auth.ts": ["exports", "types"],
    "packages/shared/src/constants.ts": ["types"],
    "packages/shared/src/event-reminders.ts": ["types"]
  },
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {},
    "apps/web": {
      "ignoreFiles": ["src/entry-server.ts", "server/**", "src/stubs/**"]
    },
    "packages/db": {
      "ignoreFiles": ["scripts/**"],
      "ignoreDependencies": ["uuidv7"]
    },
    "packages/e2e": {
      "ignoreFiles": ["global-setup.ts"],
      "entry": ["helpers/seed-dev-data.ts", "shard-by-duration.ts"],
      "ignoreDependencies": ["better-auth"]
    },
    "packages/jobs": {
      "entry": ["src/*.ts", "src/handlers/*.ts", "src/lib/*.ts"]
    },
    "packages/notifications": {
      "entry": ["src/*.ts", "src/send/*.ts"]
    },
    "packages/whatsapp": {},
    "packages/email": {
      "ignoreDependencies": ["react", "@types/react"]
    },
    "packages/design-system": {
      "ignoreFiles": ["components/**", "hooks/**"],
      "ignoreDependencies": ["@tailwindcss/.*"]
    },
    "packages/editor": {
      "entry": ["src/*.tsx"],
      "ignoreFiles": ["components/**"]
    }
  }
}
